{
  "name": "agent-tool-generator",
  "version": "0.0.6",
  "description": "Generate AI SDK tools from OpenAPI/Swagger specs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-tool-generator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "test": "tsx --env-file=.env src/test.ts",
    "generate": "tsx src/cli.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "tools"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.0",
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "ai": "^5.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
